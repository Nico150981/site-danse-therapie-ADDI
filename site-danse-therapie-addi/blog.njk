---
layout: layouts/base.njk
titre: "Journal"
description: "Textes et réflexions autour de la danse-thérapie et de la médiation créative."
permalink: "/blog/"
---
<div class="conteneur au-scroll" style="padding-block: var(--espace-section)">
  <div class="section-tete">
    <span class="eyebrow">Journal</span>
    <h1>Textes &amp; réflexions</h1>
  </div>
  {% if articles.length > 0 %}
  <ul class="liste-articles">
    {% for a in articles %}
    <li class="article-carte">
      <h3><a href="/blog/{{ a.slug }}/">{{ a.titre }}</a></h3>
      {% if a.datePublication %}<time datetime="{{ a.datePublication }}">{{ a.datePublication | dateFr }}</time>{% endif %}
      <p>{{ a.resume or a.contenu }}</p>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p>Les premiers articles arrivent bientôt.</p>
  {% endif %}
</div>
