{% if schema == "Article" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ titre | jsonStr | safe }},
  "description": {{ (description or site.description) | jsonStr | safe }},
  "image": {{ (site.url + (image or "/images/og-image.jpg")) | jsonStr | safe }},
  "datePublished": {{ (datePublication or "") | jsonStr | safe }},
  "author": { "@type": "Person", "name": {{ site.nom | jsonStr | safe }} },
  "publisher": { "@type": "Organization", "name": {{ site.nom | jsonStr | safe }} },
  "mainEntityOfPage": {{ (site.url + page.url) | jsonStr | safe }}
}
</script>
{% elif schema == "Service" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": {{ titre | jsonStr | safe }},
  "name": {{ titre | jsonStr | safe }},
  "description": {{ (description or site.description) | jsonStr | safe }},
  "provider": { "@type": "LocalBusiness", "name": {{ site.nom | jsonStr | safe }} },
  "areaServed": {{ (site.ville or "France") | jsonStr | safe }}
}
</script>
{% endif %}

{% if faq and faq.length > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faq %}
    {
      "@type": "Question",
      "name": {{ item.question | jsonStr | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ item.reponse | jsonStr | safe }} }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
