---
layout: layouts/base.njk
pagination:
  data: articles
  size: 1
  alias: item
permalink: "/blog/{{ item.slug }}/"
schema: "Article"
eleventyComputed:
  titre: "{{ item.titre }}"
  description: "{{ item.resume or item.titre }}"
  image: "{{ item.image }}"
  datePublication: "{{ item.datePublication }}"
---
<article class="conteneur au-scroll" style="padding-block: var(--espace-section); max-width: 42rem;">
  <p><a href="/blog/">← Retour au journal</a></p>
  <h1>{{ item.titre }}</h1>
  {% if item.datePublication %}<time datetime="{{ item.datePublication }}">{{ item.datePublication | dateFr }}</time>{% endif %}
  {% if item.image %}
  {% image item.image, item.titre %}
  {% endif %}
  <div class="contenu-riche">
    {{ item.contenu | safe }}
  </div>
</article>
