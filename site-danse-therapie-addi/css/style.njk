---
permalink: "css/style.css"
eleventyExcludeFromCollections: true
---
/* ==========================================================================
   Feuille de style générée à partir de _data/site.js
   -> Pour changer les couleurs ou les polices de tout le site,
      modifiez uniquement _data/site.js, pas ce fichier.
   ========================================================================== */

:root {
  --encre: {{ site.couleurs.encre }};
  --ivoire: {{ site.couleurs.ivoire }};
  --nuit: {{ site.couleurs.nuit }};
  --brique: {{ site.couleurs.brique }};
  --brique-sombre: {{ site.couleurs.briqueSombre }};
  --mousse: {{ site.couleurs.mousse }};
  --ocre: {{ site.couleurs.ocre }};

  --police-display: "Fraunces", ui-serif, Georgia, serif;
  --police-corps: "Karla", ui-sans-serif, system-ui, sans-serif;

  --largeur-max: 72rem;
  --espace-section: clamp(3.5rem, 6vw, 7rem);
  --rayon: 6px;
}

/* --- Réinitialisation minimale -------------------------------------------- */
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; }
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

body {
  margin: 0;
  font-family: var(--police-corps);
  color: var(--encre);
  background: var(--ivoire);
  line-height: 1.65;
  font-size: 1.0625rem;
}

img { max-width: 100%; height: auto; display: block; }
a { color: var(--brique); }
a:hover { color: var(--brique-sombre); }

h1, h2, h3, h4 {
  font-family: var(--police-display);
  font-weight: 600;
  line-height: 1.15;
  margin: 0 0 0.6em;
  color: var(--encre);
}
h1 { font-size: clamp(2.2rem, 4vw + 1rem, 3.6rem); font-weight: 400; }
h2 { font-size: clamp(1.6rem, 2vw + 1rem, 2.4rem); }
h3 { font-size: clamp(1.15rem, 1vw + 1rem, 1.5rem); }
p { margin: 0 0 1.1em; max-width: 65ch; }

.conteneur {
  max-width: var(--largeur-max);
  margin-inline: auto;
  padding-inline: 1.5rem;
}

/* --- Accessibilité : lien d'évitement + focus visible --------------------- */
.visually-hidden {
  position: absolute; width: 1px; height: 1px; overflow: hidden;
  clip: rect(0 0 0 0); white-space: nowrap;
}
.lien-evitement {
  position: absolute;
  left: 1rem; top: -4rem;
  background: var(--nuit);
  color: var(--ivoire);
  padding: 0.75rem 1.25rem;
  border-radius: var(--rayon);
  z-index: 100;
  transition: top 0.2s ease;
}
.lien-evitement:focus { top: 1rem; }

:focus-visible {
  outline: 3px solid var(--ocre);
  outline-offset: 3px;
}

/* --- En-tête / navigation -------------------------------------------------- */
.en-tete { background: var(--ivoire); border-bottom: 1px solid rgba(43,38,34,0.08); }
.en-tete__barre {
  display: flex; align-items: center; justify-content: space-between;
  padding-block: 1.1rem;
}
.marque {
  font-family: var(--police-display);
  font-size: 1.35rem;
  text-decoration: none;
  color: var(--encre);
}
.nav-principale ul {
  list-style: none; display: flex; gap: 1.75rem;
  margin: 0; padding: 0; align-items: center;
}
.nav-principale a {
  text-decoration: none; color: var(--encre); font-weight: 500;
  padding-bottom: 2px; border-bottom: 2px solid transparent;
}
.nav-principale a:hover { border-bottom-color: var(--brique); color: var(--encre); }
.nav-principale__cta {
  background: var(--brique); color: var(--ivoire) !important;
  padding: 0.5rem 1.1rem; border-radius: 999px; border-bottom: none !important;
}
.nav-principale__cta:hover { background: var(--brique-sombre); }

.bascule-nav {
  display: none;
  background: none; border: none; cursor: pointer; padding: 0.5rem;
}
.bascule-nav__icone,
.bascule-nav__icone::before,
.bascule-nav__icone::after {
  display: block; width: 24px; height: 2px; background: var(--encre);
  position: relative; transition: transform 0.2s ease, opacity 0.2s ease;
}
.bascule-nav__icone::before, .bascule-nav__icone::after { content: ""; position: absolute; }
.bascule-nav__icone::before { top: -7px; }
.bascule-nav__icone::after { top: 7px; }

@media (max-width: 45rem) {
  .bascule-nav { display: block; }
  .nav-principale {
    display: none;
    position: absolute; inset-inline: 0; top: 100%;
    background: var(--ivoire); border-bottom: 1px solid rgba(43,38,34,0.1);
    padding: 1rem 1.5rem 1.5rem;
  }
  .nav-principale[data-ouvert="true"] { display: block; }
  .nav-principale ul { flex-direction: column; align-items: flex-start; gap: 1rem; }
  .en-tete__barre { position: relative; }
}

/* --- Trait-signature (motif de geste réutilisé) ---------------------------- */
.trait-signature {
  display: block;
  height: var(--trait-hauteur, 140px);
  width: 100%;
  overflow: visible;
}
.trait-signature path {
  fill: none;
  stroke: var(--ocre);
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
}
.trait-signature--pied { height: 32px; margin-bottom: 0.75rem; }

/* --- Hero ------------------------------------------------------------------ */
.hero {
  background: var(--nuit);
  color: var(--ivoire);
  padding-block: clamp(4rem, 8vw, 7rem) clamp(3rem, 6vw, 5rem);
  position: relative;
  overflow: hidden;
}
.hero h1 { color: var(--ivoire); }
.hero__sous-titre {
  font-size: clamp(1.05rem, 1vw + 0.9rem, 1.3rem);
  color: rgba(246,241,231,0.82);
  max-width: 42ch;
}
.hero__trait { margin-block: 1.5rem 2rem; max-width: 40rem; }
.hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

.bouton {
  display: inline-block;
  font-family: var(--police-corps);
  font-weight: 700;
  text-decoration: none;
  padding: 0.85rem 1.6rem;
  border-radius: 999px;
  background: var(--brique);
  color: var(--ivoire);
  border: 2px solid transparent;
  transition: background 0.2s ease, transform 0.15s ease;
}
.bouton:hover { background: var(--brique-sombre); color: var(--ivoire); transform: translateY(-1px); }
.bouton--fantome {
  background: transparent; color: var(--ivoire); border-color: rgba(246,241,231,0.5);
}
.bouton--fantome:hover { background: rgba(246,241,231,0.1); color: var(--ivoire); }

/* --- Sections génériques ---------------------------------------------------- */
section { padding-block: var(--espace-section); }
.section-tete { max-width: 42rem; margin-bottom: 2.5rem; }
.eyebrow {
  font-family: var(--police-corps); font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.14em; font-size: 0.78rem; color: var(--mousse);
  display: block; margin-bottom: 0.75rem;
}

/* --- L'arc d'une séance (séquence réelle -> numérotation justifiée) --------- */
.arc { display: grid; gap: 2.5rem; grid-template-columns: repeat(3, 1fr); }
.arc__etape { position: relative; padding-left: 3.2rem; }
.arc__numero {
  font-family: var(--police-display);
  position: absolute; left: 0; top: -0.2rem;
  font-size: 1.6rem; color: var(--ocre);
}
@media (max-width: 45rem) { .arc { grid-template-columns: 1fr; } }

/* --- Approche (sans cartes-icônes génériques) ------------------------------- */
.approche { display: grid; gap: 3rem; grid-template-columns: repeat(2, 1fr); }
.approche__bloc { border-top: 2px solid var(--encre); padding-top: 1.25rem; }
@media (max-width: 45rem) { .approche { grid-template-columns: 1fr; } }

/* --- Témoignages ------------------------------------------------------------ */
.temoignage {
  font-family: var(--police-display);
  font-size: clamp(1.2rem, 1.4vw + 1rem, 1.6rem);
  font-weight: 400;
  max-width: 46rem;
  position: relative;
  padding-left: 1.5rem;
  border-left: 3px solid var(--brique);
}
.temoignage cite {
  display: block; font-family: var(--police-corps); font-style: normal;
  font-size: 0.95rem; margin-top: 0.75rem; color: var(--mousse); font-weight: 700;
}

/* --- Listes d'articles / blog ------------------------------------------------ */
.liste-articles { list-style: none; margin: 0; padding: 0; display: grid; gap: 2rem; }
.article-carte h3 { margin-bottom: 0.3rem; }
.article-carte time { font-size: 0.85rem; color: var(--mousse); }

/* --- Formulaire (contact) ---------------------------------------------------- */
form { display: flex; flex-direction: column; gap: 1.1rem; max-width: 32rem; }
label { font-weight: 700; margin-bottom: 0.35rem; display: block; }
input, textarea {
  width: 100%;
  font-family: inherit; font-size: 1rem;
  padding: 0.75rem 0.9rem;
  border: 1.5px solid rgba(43,38,34,0.25);
  border-radius: var(--rayon);
  background: #fff;
  color: var(--encre);
}
input:focus, textarea:focus { border-color: var(--brique); }
.champ-consentement { display: flex; align-items: flex-start; gap: 0.6rem; font-weight: 400; }
.champ-consentement input { width: auto; margin-top: 0.3rem; }

/* --- Pied de page ------------------------------------------------------------ */
.pied { background: var(--nuit); color: rgba(246,241,231,0.85); padding-block: 3rem; margin-top: var(--espace-section); }
.pied a { color: var(--ivoire); }
.pied__grille { display: grid; gap: 2rem; grid-template-columns: repeat(3, 1fr); }
.pied__marque { font-family: var(--police-display); font-size: 1.2rem; color: var(--ivoire); margin-bottom: 0.3rem; }
.pied__liens { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
@media (max-width: 45rem) { .pied__grille { grid-template-columns: 1fr; } }

/* --- Apparitions au scroll (respecte prefers-reduced-motion plus haut) ------ */
.au-scroll { opacity: 0; transform: translateY(16px); transition: opacity 0.6s ease, transform 0.6s ease; }
.au-scroll.est-visible { opacity: 1; transform: translateY(0); }
